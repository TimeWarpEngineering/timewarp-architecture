<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <IsRoslynComponent>true</IsRoslynComponent>
    <!-- Suppress RS1041: Source generator intentionally targets net10.0 for CLI usage -->
    <!-- Suppress CA1031: Source generators must be resilient and catch general exceptions -->
    <NoWarn>$(NoWarn);RS1041;CA1031</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" PrivateAssets="all" />
    <PackageReference Include="Microsoft.CodeAnalysis.Analyzers" PrivateAssets="all" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="../timewarp-architecture-attributes/timewarp-architecture-attributes.csproj" />
  </ItemGroup>
</Project>
