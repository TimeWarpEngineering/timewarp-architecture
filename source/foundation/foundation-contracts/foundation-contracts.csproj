<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <PackageId>TimeWarp.Foundation.Contracts</PackageId>
    <Title>TimeWarp.Foundation.Contracts</Title>
    <Description>Shared contracts, request/response markers, route/auth/query source generator, and common types for the TimeWarp foundation layer.</Description>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="Ardalis.GuardClauses" />
    <PackageReference Include="FluentValidation" />
    <PackageReference Include="libphonenumber-csharp" />
    <PackageReference Include="TimeWarp.Mediator" />
    <PackageReference Include="Microsoft.Extensions.Http" />
    <PackageReference Include="Microsoft.Extensions.Options" />
    <PackageReference Include="OneOf" />
  </ItemGroup>

  <!-- The contracts mixins are now a Roslyn source generator (task 053-001). foundation-contracts
       only DEFINES the mixins (it doesn't apply them), so we build the generator (for ordering) but
       do NOT run it here; we BUNDLE its dll into this package (analyzers/dotnet/cs) so consumers of
       the package get the generator automatically via PackageReference. -->
  <PropertyGroup>
    <TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);_BundleContractsGenerator</TargetsForTfmSpecificContentInPackage>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\foundation-contracts-generators\foundation-contracts-generators.csproj"
                      ReferenceOutputAssembly="false" PrivateAssets="all" />
  </ItemGroup>

  <!-- Ask the generator project for its real output path (no hardcoded bin/config/TFM) and bundle
       it as an analyzer asset. -->
  <Target Name="_BundleContractsGenerator">
    <MSBuild Projects="$(MSBuildThisFileDirectory)..\foundation-contracts-generators\foundation-contracts-generators.csproj"
             Targets="GetTargetPath" RemoveProperties="TargetFramework">
      <Output TaskParameter="TargetOutputs" ItemName="_ContractsGeneratorDll" />
    </MSBuild>
    <ItemGroup>
      <TfmSpecificPackageFile Include="@(_ContractsGeneratorDll)" PackagePath="analyzers/dotnet/cs" />
    </ItemGroup>
  </Target>
</Project>
