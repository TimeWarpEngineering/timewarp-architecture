<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>TimeWarp.Architecture</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <Compile Remove="features\analytics\track-event-validiation.mixin.cs"/>
  </ItemGroup>

  <ItemGroup>
    <None Remove="features\analytics\TrackEventValidiation.mixin"/>
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="features\analytics\TrackEventValidiation.mixin"/>
    <AdditionalFiles Include="features\analytics\track-event-validiation.mixin.cs"/>
    <AdditionalFiles Include="mixins\DeleteCommand.mixin"/>
    <AdditionalFiles Include="mixins\GetListQuery.mixin"/>
    <AdditionalFiles Include="mixins\GetQuery.mixin"/>
    <AdditionalFiles Include="mixins\CreateCommand.mixin"/>
    <AdditionalFiles Include="mixins\UpdateCommand.mixin"/>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="FluentValidation"/>
    <PackageReference Include="OneOf"/>
    <PackageReference Include="TimeWarp.Mediator"/>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions"/>
    <PackageReference Include="Microsoft.Extensions.DependencyInjection"/>
    <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions"/>
    <PackageReference Include="Microsoft.Extensions.Options.ConfigurationExtensions"/>
    <PackageReference Include="Microsoft.Extensions.Options"/>
    <PackageReference Include="Morris.Moxy" PrivateAssets="all" GeneratePathProperty="true"/>
    <PackageReference Include="Passwordless"/>
    <PackageReference Include="protobuf-net.Grpc"/>
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\foundation\foundation-contracts\foundation-contracts.csproj" Condition="'$(UseFoundationPackages)' != 'true'" />
    <PackageReference Include="TimeWarp.Foundation.Contracts" Condition="'$(UseFoundationPackages)' == 'true'" />
  </ItemGroup>

  <ItemGroup>
    <!-- The foundation-contracts mixins (RouteMixin, IAuthApiRequestMixin, IOpenDataQueryParametersMixin)
         are now a bundled Roslyn source generator (task 053-001). In repo mode (project refs) the
         generator is referenced as an Analyzer; in package mode it flows from the
         TimeWarp.Foundation.Contracts package automatically. -->
    <ProjectReference Include="..\..\..\foundation\foundation-contracts-generators\foundation-contracts-generators.csproj"
                      OutputItemType="Analyzer" ReferenceOutputAssembly="false"
                      Condition="'$(UseFoundationPackages)' != 'true'" />
  </ItemGroup>

  <ItemGroup>
    <Folder Include="features\auth\commands\"/>
  </ItemGroup>

</Project>
