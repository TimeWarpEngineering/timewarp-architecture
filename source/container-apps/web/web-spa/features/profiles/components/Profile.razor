@namespace TimeWarp.Architecture.Features.Profiles
@inherits BaseComponent
@inject NavigationManager NavigationManager
@inject HttpClient HttpClient

@code {
  private async Task HandleSignIn()
  {
    await NoSubRouteState.ChangeRoute(newRoute: "authentication/login");
  }
  private void HandleSignOut()
  {
    NavigationManager.NavigateToLogout("authentication/logout");
  }
  private async Task HandleYourProfile()
  {
    await NoSubRouteState.ChangeRoute(newRoute: ProfilePage.GetPageUrl());
  }
  private async Task HandleSettings()
  {
    await NoSubRouteState.ChangeRoute(newRoute: SettingsPage.GetPageUrl());
  }
  protected override async Task OnInitializedAsync()
  {
    // During server prerender the WASM HttpClient (BaseAddress from HostEnvironment) does not
    // exist, so API calls throw "BaseAddress must be set". Only fetch once interactive.
    if (!RendererInfo.IsInteractive) return;

    if (await CheckAuthorization())
    {
      await ProfileState.FetchProfileData();
    }
  }
}

@* V5 removed FluentPersona — compose FluentAvatar + label as the menu trigger.
   The trigger lives INSIDE FluentMenu via slot="trigger" so the web component wires
   the click-to-open itself (the external Trigger=<id> attribute did not render in rc.3). *@
<FluentMenu>
  <div slot="@FluentSlot.Trigger" class="@($"{Id} profile-persona")">
    <FluentAvatar Image=@ProfileState.Avatar Name=@ProfileState.Alias Size="AvatarSize.Size48" />
    <FluentText>@ProfileState.Alias</FluentText>
  </div>
  <FluentMenuList>
    <AuthorizeView>
      <Authorized>
        <FluentMenuItem OnClick=@HandleYourProfile IconStart="@(new Icons.Regular.Size20.Person())">Profile</FluentMenuItem>
        <FluentMenuItem OnClick=@HandleSettings IconStart="@(new Icons.Regular.Size20.Settings())">Settings</FluentMenuItem>
        <FluentMenuItem OnClick=@HandleSignOut IconStart="@(new Icons.Regular.Size20.SignOut())">Sign out</FluentMenuItem>
      </Authorized>
      <NotAuthorized>
        <FluentMenuItem OnClick=@HandleSignIn IconStart="@(new Icons.Regular.Size20.Person())">Sign-in</FluentMenuItem>
      </NotAuthorized>
    </AuthorizeView>
  </FluentMenuList>
</FluentMenu>

<style>
  @($@"
    .{Id}.profile-persona {{
      display: inline-flex;
      align-items: center;
      gap: 8px;
      cursor: pointer;
    }}
  ")
</style>


