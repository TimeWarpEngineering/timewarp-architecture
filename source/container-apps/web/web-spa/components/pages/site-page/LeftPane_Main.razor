@namespace TimeWarp.Architecture.Components.Pages.SitePage
@inherits BaseComponent

@code {

}

<FluentNav Class=@BaseCssBuilder.ToString()>
  <TimeWarpNavLink TPage=HomePage />
  <FluentNavCategory Title="Pages">
    <TimeWarpNavLink TPage=CounterPage />
    @*#if (api)*@
    <TimeWarpNavLink TPage=WeatherForecastsPage />
    @*#endif*@
    @*#if (grpc)*@
    <TimeWarpNavLink TPage=SuperheroPage />
    @*#endif*@
    <TimeWarpNavLink TPage=ChatPage />
  </FluentNavCategory>
  <FluentNavCategory Title="Developer">
    <TimeWarpNavLink TPage=ExampleTimeWarpPage />
    <TimeWarpNavLink TPage=ExampleSitePage />
    <TimeWarpNavLink TPage=TestPage />
    <TimeWarpNavLink TPage=EventStreamPage />
    <TimeWarpNavLink TPage=ServicesPage />
    <TimeWarpNavLink TPage=UserClaimsPage />
  </FluentNavCategory>
  <FluentNavCategory Title="Open API">
    <FluentNavItem IconRest=@(new Icons.Regular.Size20.Book()) Href="/" Match=NavLinkMatch.All>Web-Server</FluentNavItem>
    <FluentNavItem IconRest=@(new Icons.Regular.Size20.Book()) Href="/" Match=NavLinkMatch.All>Api-Server</FluentNavItem>
  </FluentNavCategory>
  <FluentNavCategory Title="External">
    <FluentNavItem IconRest=@(new Icons.Regular.Size20.Link()) Href="/" Match=NavLinkMatch.All>The Freeze Team</FluentNavItem>
    <FluentNavItem Href="/" Match=NavLinkMatch.All>
      <TimeWarp.Simple.Icons.GithubIcon class="w-5 h-5 fill-slate-400" /> GitHub
    </FluentNavItem>
  </FluentNavCategory>
  <TimeWarpNavLink TPage=SettingsPage />
</FluentNav>

<style>
  @($@"
    .{Id} {{
      width: 100%;
    }}
  ")
</style>
