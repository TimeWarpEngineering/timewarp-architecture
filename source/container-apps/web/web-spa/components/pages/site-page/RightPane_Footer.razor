@namespace TimeWarp.Architecture.Components.Pages.SitePage
@inherits BaseComponent
@code {
  [Parameter] public RenderFragment? CustomContent { get; set; }
  private string? Version => ApplicationState.Version;
  private bool IsActive => ActionTrackingState.IsActive;

  private async Task ShowAssemblyInfoModal() =>
    await ApplicationState.SetActiveModal(AssemblyInfoModal.ModalId);
}

@* V5 removed FluentFooter — use a native element styled via the .{Id} scope handle
   (see skills/blazor-css-strategy). *@
<footer class=@BaseCssBuilder.ToString() style="display: flex; flex-direction: row; height: var(--footer-height)">
  <FluentText>@CurrentRenderMode</FluentText>
  <FluentSpacer/>
  <FluentSpinner Class="grow" Visible=IsActive></FluentSpinner>
  <FluentSpacer/>
  <FluentButton Appearance=ButtonAppearance.Transparent @onclick=ShowAssemblyInfoModal>
    @Version
  </FluentButton>
</footer>

<style>
  @($@"
    .{Id} {{
      width: 100%;
    }}
  ")
</style>
