@namespace TimeWarp.Architecture.Components.Pages.SitePage
@*
  Site-specific page layout built on TimeWarpPage.
  The left pane and right pane footer are preconfigured while page and aside pane regions remain customizable.
*@
@inherits BaseComponent
@using TimeWarp.Architecture.Components.Pages.SitePage
@code {
  /// <summary>
  /// Gets or sets custom content for the page pane header.
  /// </summary>
  [Parameter] public RenderFragment? PagePane_HeaderContent { get; set; }

  /// <summary>
  /// Gets or sets custom content for the page pane main region.
  /// </summary>
  [Parameter] public RenderFragment? PagePane_MainContent { get; set; }

  /// <summary>
  /// Gets or sets custom content for the page pane footer.
  /// </summary>
  [Parameter] public RenderFragment? PagePane_FooterContent { get; set; }

  /// <summary>
  /// Gets or sets custom content for the aside pane header.
  /// </summary>
  [Parameter] public RenderFragment? AsidePane_HeaderContent { get; set; }

  /// <summary>
  /// Gets or sets custom content for the aside pane main region.
  /// </summary>
  [Parameter] public RenderFragment? AsidePane_MainContent { get; set; }

  /// <summary>
  /// Gets or sets custom content for the aside pane footer.
  /// </summary>
  [Parameter] public RenderFragment? AsidePane_FooterContent { get; set; }

  /// <summary>
  /// Gets or sets a value indicating whether the preconfigured left pane is visible.
  /// </summary>
  [Parameter] public bool ShowLeftPane { get; set; } = true;

  /// <summary>
  /// Gets or sets a value indicating whether the site footer is visible.
  /// </summary>
  [Parameter] public bool ShowSiteFooter { get; set; } = true;

  /// <summary>
  /// Gets or sets a value indicating whether placeholder content is displayed in empty regions.
  /// </summary>
  [Parameter] public bool ShowPlaceholders { get; set; } = false;
}

<TimeWarpPage
  PagePane_HeaderContent=PagePane_HeaderContent
  PagePane_MainContent=PagePane_MainContent
  PagePane_FooterContent=PagePane_FooterContent
  AsidePane_HeaderContent=AsidePane_HeaderContent
  AsidePane_MainContent=AsidePane_MainContent
  AsidePane_FooterContent=AsidePane_FooterContent
  ShowLeftPane=ShowLeftPane
  ShowSiteFooter=ShowSiteFooter
  ShowPlaceholders=ShowPlaceholders
>
  <LeftPane_HeaderContent>
    <LeftPane_Header/>
  </LeftPane_HeaderContent>
  <LeftPane_MainContent>
    <LeftPane_Main/>
  </LeftPane_MainContent>
  <LeftPane_FooterContent>
    <LeftPane_Footer/>
  </LeftPane_FooterContent>
  <RightPane_HeaderContent>
    <RightPane_Header/>
  </RightPane_HeaderContent>
  <RightPane_FooterContent>
    <RightPane_Footer/>
  </RightPane_FooterContent>
</TimeWarpPage>
