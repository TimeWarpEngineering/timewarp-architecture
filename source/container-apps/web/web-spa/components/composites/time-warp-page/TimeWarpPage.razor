@namespace TimeWarp.Architecture.Components.Composites.TimeWarpPage
@*
  Flexible multi-pane page layout built on FluentMultiSplitter.
  Structure: left pane and right pane; each pane has header, main, and footer regions.
  The right pane also contains page and aside regions for primary and supplementary content.
  Use the RenderFragment parameters to inject custom content and the Show* parameters to control layout visibility.
*@
@{
  #pragma warning disable FluentMultiSplitter
}
@inherits BaseComponent

@using TimeWarp.Architecture.Components.Composites.TimeWarpPage
@using TimeWarp.Architecture.Components.Composites.TimeWarpPage.RightPane
@using TimeWarp.Architecture.Components.Composites.TimeWarpPage.LeftPane

@code
{
  /// <summary>
  /// Gets or sets custom content for the left pane header.
  /// </summary>
  [Parameter] public RenderFragment? LeftPane_HeaderContent { get; set; }

  /// <summary>
  /// Gets or sets custom content for the left pane main region.
  /// </summary>
  [Parameter] public RenderFragment? LeftPane_MainContent { get; set; }

  /// <summary>
  /// Gets or sets custom content for the left pane footer.
  /// </summary>
  [Parameter] public RenderFragment? LeftPane_FooterContent { get; set; }
  [Parameter] public RenderFragment? NavLink { get; set; }

  /// <summary>
  /// Gets or sets custom content for the right pane header.
  /// </summary>
  [Parameter] public RenderFragment? RightPane_HeaderContent { get; set; }

  /// <summary>
  /// Gets or sets custom content for the right pane footer.
  /// </summary>
  [Parameter] public RenderFragment? RightPane_FooterContent { get; set; }

  /// <summary>
  /// Gets or sets custom content for the page pane header.
  /// </summary>
  [Parameter] public RenderFragment? PagePane_HeaderContent { get; set; }

  /// <summary>
  /// Gets or sets custom content for the page pane main region.
  /// </summary>
  [Parameter] public RenderFragment? PagePane_MainContent { get; set; }

  /// <summary>
  /// Gets or sets custom content for the page pane footer.
  /// </summary>
  [Parameter] public RenderFragment? PagePane_FooterContent { get; set; }

  /// <summary>
  /// Gets or sets custom content for the aside pane header.
  /// </summary>
  [Parameter] public RenderFragment? AsidePane_HeaderContent { get; set; }

  /// <summary>
  /// Gets or sets custom content for the aside pane main region.
  /// </summary>
  [Parameter] public RenderFragment? AsidePane_MainContent { get; set; }

  /// <summary>
  /// Gets or sets custom content for the aside pane footer.
  /// </summary>
  [Parameter] public RenderFragment? AsidePane_FooterContent { get; set; }

  /// <summary>
  /// Gets or sets a value indicating whether the collapsible left pane is visible.
  /// </summary>
  [Parameter] public bool ShowLeftPane { get; set; } = true;

  /// <summary>
  /// Gets or sets a value indicating whether the site footer is visible.
  /// </summary>
  [Parameter] public bool ShowSiteFooter { get; set; } = true;

  /// <summary>
  /// Gets or sets a value indicating whether placeholder content is displayed in empty regions.
  /// </summary>
  [Parameter] public bool ShowPlaceholders { get; set; } = false;

  private FluentMultiSplitter FluentMultiSplitter { get; set; } = null!;
  private FluentMultiSplitterPane? LeftPane { get; set; }

  protected override void OnAfterRender(bool firstRender)
  {
    base.OnAfterRender(firstRender);
    if (firstRender)
    {
      if (LeftPane == null) return;

      if (!ShowLeftPane)
      {
        FluentMultiSplitter.RemovePane(LeftPane);
      }
    }
  }
}

<CascadingValue Value="this">
  <FluentMultiSplitter ref=FluentMultiSplitter Class=@($"{Id} timewarp-page") >
    <FluentMultiSplitterPane ref=LeftPane Size="20%" Min="275px" Max="70%" Collapsible=ShowLeftPane Collapsed=@(!ShowLeftPane)>
      <LeftPane />
    </FluentMultiSplitterPane>
    <FluentMultiSplitterPane Size="80%">
      <RightPane />
    </FluentMultiSplitterPane>
  </FluentMultiSplitter>
</CascadingValue>

<style>
  @($@"
    .{Id} {{
      min-height: 100vh;
    }}
  ")
</style>
