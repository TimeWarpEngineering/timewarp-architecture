@namespace TimeWarp.Architecture.Components
@typeparam TPage where TPage : INavigableComponent, IStaticRoute

<AuthorizeView Policy=@TPage.Policy>
  <Authorized>
    <FluentNavItem
      IconRest=TPage.NavIcon
      Href=@TPage.GetPageUrl()
      Match=NavLinkMatch.All>
      @TPage.Title
    </FluentNavItem>
  </Authorized>
</AuthorizeView>
