@namespace TimeWarp.Architecture.Components
@inherits BaseComponent
@using TimeWarp.Architecture.Features.Profiles
@using TimeWarp.Features.Theme
@*
  The single app-shell page component (replaces the old multi-splitter TimeWarpPage,
  SitePage, SidebarPage, StackedPage). Pages wrap their content in it:

      <TimeWarpPage Title="Settings"> ...content... </TimeWarpPage>

  Built on FluentUI v5 FluentLayout. MainLayout stays empty (just FluentProviders);
  this component owns the chrome so it gets the TimeWarp.State render-trigger / Id /
  per-navigation lifecycle that a LayoutComponentBase can't.
*@

@code {
  [Parameter] public string? Title { get; set; }
  [Parameter] public RenderFragment? ChildContent { get; set; }
  [Parameter] public RenderFragment? Aside { get; set; }

  private string? ActiveModalId => ApplicationState.ActiveModalId;
  private async Task ShowAssemblyInfoModalAsync() => await ApplicationState.SetActiveModal(AssemblyInfoModal.ModalId);
}

<CascadingValue Value=@this>
  <FluentLayout Class=@($"{Id} twe-shell")>

    <FluentLayoutItem Area="LayoutArea.Header">
      <header class="twe-appbar">
        <div class="twe-brand">
          <img class="twe-brand__logo" src="images/timewarp-logo.svg" alt="TimeWarp Enterprises" />
          <span class="twe-brand__text">
            <span class="twe-brand__name">TimeWarp</span>
            <span class="twe-brand__sub">Architecture</span>
          </span>
        </div>
        <div class="twe-appbar__search">
          <FluentTextInput Placeholder="Search">
            <EndTemplate><span class="search-end">Ctrl-K</span></EndTemplate>
          </FluentTextInput>
        </div>
        <div class="twe-appbar__actions">
          <FluentButton Appearance="ButtonAppearance.Subtle" OnClick=@(async () => await ThemeState.Update(ThemeState.Theme.Dark))>
            <FluentIcon Value=@(new Icons.Regular.Size24.DarkTheme()) Color="Color.Default" />
          </FluentButton>
          <Profile />
        </div>
      </header>
    </FluentLayoutItem>

    <FluentLayoutItem Area="LayoutArea.Navigation" Width="240px">
      <NavMenu />
    </FluentLayoutItem>

    <FluentLayoutItem Area="LayoutArea.Content">
      <div class="twe-page">
        @if (!string.IsNullOrWhiteSpace(Title))
        {
          <h1 class="twe-page__title">@Title</h1>
        }
        <div class="twe-page__body">
          @ChildContent
        </div>
      </div>
    </FluentLayoutItem>

    @if (Aside is not null)
    {
      <FluentLayoutItem Area="LayoutArea.Aside" Width="300px">
        <div class="twe-aside">@Aside</div>
      </FluentLayoutItem>
    }

    <FluentLayoutItem Area="LayoutArea.Footer">
      <footer class="twe-footer">
        <span class="twe-footer__mode">@CurrentRenderMode</span>
        <FluentSpacer />
        <FluentButton Appearance="ButtonAppearance.Transparent" @onclick=ShowAssemblyInfoModalAsync>@ApplicationState.Version</FluentButton>
      </footer>
    </FluentLayoutItem>

  </FluentLayout>
</CascadingValue>

<ModalController ActiveModalId=@ActiveModalId>
  <ModalContainers>
    <AssemblyInfoModal />
  </ModalContainers>
</ModalController>

@* Tier-2 shell styles (skills/blazor-css-strategy): scoped to the fixed .twe-shell root
   class because they style FluentUI light-DOM children (fluent-nav, fluent-text-input)
   which CSS isolation can't reach. Verbatim string so CSS braces are literal. *@
<style>
  @(@"
    .twe-shell .twe-appbar {
      display: flex; align-items: center; gap: 12px;
      width: 100%; height: 56px; padding: 0 16px;
      background: var(--twe-paper); border-bottom: 3px solid var(--twe-green);
    }
    .twe-shell .twe-appbar__search { flex: 0 1 520px; width: 520px; margin-inline: auto; }
    .twe-shell .twe-appbar__search fluent-text-input { width: 100%; }
    .twe-shell .twe-appbar__actions { flex: 0 0 auto; display: flex; align-items: center; gap: 8px; }
    .twe-shell .search-end { white-space: nowrap; color: var(--twe-muted); font-size: var(--twe-text-helper); }

    .twe-shell .twe-brand { display: inline-flex; align-items: center; gap: 10px; padding: 0 6px; }
    .twe-shell .twe-brand__logo { height: 34px; width: auto; flex: none; display: block; }
    .twe-shell .twe-brand__text { display: flex; flex-direction: column; line-height: 1.04; }
    .twe-shell .twe-brand__name { font-weight: 800; font-size: 16px; letter-spacing: -0.02em; color: var(--twe-ink); }
    .twe-shell .twe-brand__sub { font-size: 10px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--twe-muted); }

    .twe-shell .twe-nav { height: 100%; padding: 8px; background: var(--twe-paper-2); border-right: 1px solid var(--twe-rule); }

    .twe-shell .twe-page { padding: 20px 28px 28px; }
    .twe-shell .twe-page__title { margin: 0 0 16px; font-size: var(--twe-text-page-title); font-weight: 700; letter-spacing: -0.015em; color: var(--twe-ink); }
    .twe-shell .twe-page__title:focus { outline: none; }
    .twe-shell .twe-page__body { color: var(--twe-ink); }

    .twe-shell .twe-aside { padding: 20px; border-left: 1px solid var(--twe-rule); height: 100%; }

    .twe-shell .twe-footer {
      display: flex; align-items: center; gap: 12px; width: 100%; padding: 4px 16px;
      border-top: 1px solid var(--twe-rule); background: var(--twe-paper);
      color: var(--twe-muted); font-size: var(--twe-text-helper);
    }
  ")
</style>
