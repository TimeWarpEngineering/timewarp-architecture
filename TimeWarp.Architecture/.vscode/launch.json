  "version": "0.2.0",
  "configurations": [
    {
      "name": ".NET Core Launch (console)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build",
      "program": "dotnet",
      "args": ["fixie", "Tests/ContainerApps/Web/Web.Server.Integration.Tests", "--debug"],
      "cwd": "${workspaceFolder}",
      "stopAtEntry": false,
      "console": "internalConsole"
    },
    {
      "name": "C#: Web.Server.Integration.Tests",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/Tests/ContainerApps/Web/Web.Server.Integration.Tests/Web.Server.Integration.Tests.csproj",
      "launchConfigurationId": "TargetFramework=;Web.Server.Integration.Tests"
    }
  ]
}